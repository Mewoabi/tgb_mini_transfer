{
  "info": {
    "name": "MiniTransfer API",
    "description": "Collection de test de l'API MiniTransfer. L'inscription et la connexion enregistrent automatiquement le token JWT dans la variable de collection {{token}}, utilisée par les requêtes protégées.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@mail.com\",\n  \"phone\": \"+237600000001\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "register" ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@mail.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "login" ]
            }
          }
        },
        {
          "name": "Register (destinataire Bob)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"bob@mail.com\",\n  \"phone\": \"+237600000002\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "auth", "register" ]
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/balance",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "wallet", "balance" ]
            }
          }
        }
      ]
    },
    {
      "name": "Transfers",
      "item": [
        {
          "name": "Create transfer",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient\": \"bob@mail.com\",\n  \"amount\": 3000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transfers",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transfers" ]
            }
          }
        },
        {
          "name": "History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/history",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "transfers", "history" ]
            }
          }
        }
      ]
    }
  ]
}
